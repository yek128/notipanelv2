<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 알림 읽기 권한 -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
        tools:ignore="ProtectedPermissions"
        xmlns:tools="http://schemas.android.com/tools"/>
    <!-- 오버레이(화면 위에 그리기) 권한 - 플로팅 패널용 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <!-- 부팅 후 자동 시작 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- 진동 -->
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- 포그라운드 서비스 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NotificationEdge">

        <!-- 메인 설정 화면 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ============================================
             핵심: 알림 리스너 서비스
             카톡, 문자 등 모든 알림 내용을 가로채는 서비스
             ============================================ -->
        <service
            android:name=".NotificationListener"
            android:label="@string/app_name"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!-- ============================================
             Samsung Edge Panel Provider
             갤럭시 엣지 패널에 표시되는 패널 정의
             ============================================ -->
        <receiver
            android:name=".EdgePanelProvider"
            android:label="@string/edge_panel_name"
            android:exported="true">
            <intent-filter>
                <!-- 삼성 엣지 패널 업데이트 액션 -->
                <action android:name="com.samsung.android.cocktailbar.action.COCKTAIL_UPDATE"/>
                <action android:name="com.samsung.android.cocktailbar.action.COCKTAIL_ENABLED"/>
                <action android:name="com.samsung.android.cocktailbar.action.COCKTAIL_DISABLED"/>
                <!-- 커스텀 알림 업데이트 액션 -->
                <action android:name="com.example.notificationedge.UPDATE_PANEL"/>
            </intent-filter>
            <!-- 엣지 패널 메타데이터 -->
            <meta-data
                android:name="com.samsung.android.cocktailbar.CocktailProvider"
                android:resource="@xml/edge_panel_info"/>
        </receiver>

        <!-- 플로팅 패널 서비스 (엣지 패널 미지원 기기 또는 보조용) -->
        <service
            android:name=".FloatingPanelService"
            android:exported="false"
            android:foregroundServiceType="specialUse"/>

        <!-- 부팅 완료 수신기 -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>

    </application>

</manifest>
